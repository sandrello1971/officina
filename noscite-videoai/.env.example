# Configurazione noscite-videoai — copia in .env e compila i valori.
# I segreti reali NON vanno committati (.env è in .gitignore).

# --- API key (obbligatorie) ---
ANTHROPIC_API_KEY=sk-ant-...        # Claude Vision + chat RAG
GROQ_API_KEY=gsk_...                # Groq Whisper (trascrizione audio)

# --- Pipeline ingest video ---
FRAMES_PER_SECOND=0.5               # frame estratti al secondo
CHUNK_WINDOW_SECONDS=30             # finestra chunk trascrizione
CHUNK_OVERLAP_SECONDS=8             # overlap tra chunk
MAX_FRAMES_TO_ANALYZE=50           # max frame analizzati con Vision

# --- Storage ---
DATA_DIR=./data                     # directory dati (video, frame, chroma, sqlite, job)

# --- Trascrizione audio / YouTube ---
MAX_TRANSCRIBE_DURATION_SECONDS=10800   # limite durata sorgente (default 3h)

# --- Auth ---
# NOTA: attualmente NON usata dal codice. Gli endpoint API sono senza
# autenticazione (il servizio è esposto solo su 127.0.0.1 dietro reverse proxy).
# Lasciata documentata perché presente nel .env di produzione.
VIDEO_AI_SECRET=changeme
