# Obsidian AI Metadata Agent — variabili d'ambiente
# Copia questo file in .env e compila i valori

# Chiave API Anthropic (obbligatoria)
ANTHROPIC_API_KEY=sk-ant-...

# Chiave API Local REST Plugin di Obsidian (opzionale, per apertura file)
OBSIDIAN_API_KEY=

# Percorso assoluto al vault Obsidian (usato da html_dashboard e dashboard_server)
OBSIDIAN_VAULT=/path/to/your/obsidian/vault

# Porta del server dashboard (default: 5051)
PKM_PORT=5051
